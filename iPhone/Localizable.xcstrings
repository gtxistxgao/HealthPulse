    "healthkit.auth.denied" : {
      "comment" : "Error message when HealthKit access is unavailable, set on DashboardViewModel.errorMessage. The arrow › separates the iOS Settings path (was: 无法访问健康数据,请在「设置 › 健康」中授权 HealthPulse。).",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Kein Zugriff auf Gesundheitsdaten. Erlaube HealthPulse unter Einstellungen › Health." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Can't access health data. Allow HealthPulse in Settings › Health." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "No se puede acceder a los datos de salud. Autoriza HealthPulse en Ajustes › Salud." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Impossible d'accéder aux données de santé. Autorisez HealthPulse dans Réglages › Santé." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ヘルスデータにアクセスできません。「設定 › ヘルスケア」で HealthPulse を許可してください。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "건강 데이터에 접근할 수 없습니다. 설정 › 건강에서 HealthPulse를 허용하세요." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无法访问健康数据,请在「设置 › 健康」中授权 HealthPulse。" } }
      }
