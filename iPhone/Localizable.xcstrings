    "dashboard.guidance.body" : {
      "comment" : "Empty/authorization guidance body shown when there is no snapshot and no error (was: 授权访问「健康」数据后,这里会显示你的恢复与能量概览。).",
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sobald du den Zugriff auf deine Gesundheitsdaten erlaubst, erscheint hier deine Übersicht zu Erholung und Energie." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Once you grant access to your Health data, your recovery and energy overview will appear here." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Cuando concedas acceso a tus datos de Salud, aquí aparecerá tu resumen de recuperación y energía." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Une fois l'accès à vos données Santé autorisé, votre aperçu de récupération et d'énergie s'affichera ici." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "「ヘルスケア」データへのアクセスを許可すると、回復とエネルギーの概要がここに表示されます。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "건강 데이터 접근을 허용하면 회복 및 에너지 요약이 여기에 표시됩니다." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "授权访问「健康」数据后,这里会显示你的恢复与能量概览。" } }
      }
    },
